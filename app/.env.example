# Copy to .env and fill in. The brain runs fine without any of these
# (it falls back to deterministic stub seeds), so you can develop with no key.

OPENAI_API_KEY=
TRANSFORM_MODEL=gpt-4o
ORACLE_MODEL=gpt-4o
# OpenAI Whisper STT for the divination mic. Unset → local Xenova whisper-tiny fallback.
STT_MODEL=whisper-1

# ElevenLabs TTS for the oracle voice into the performer's earpiece.
# Unset → browser speechSynthesis fallback. Voices are per-archetype in packages/oracles.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5

# OSC out to Anna (Ableton/Max) and Jeff (TouchDesigner/Resolume). Off by default.
OSC_ENABLED=false
OSC_HOST=127.0.0.1
OSC_PORT=57121

PORT=8787
HOST=127.0.0.1
