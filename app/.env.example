# Copy to .env and fill in. The brain runs fine without any of these
# (it falls back to deterministic stub seeds), so you can develop with no key.

ANTHROPIC_API_KEY=
TRANSFORM_MODEL=claude-opus-4-8
ORACLE_MODEL=claude-sonnet-4-6

# OSC out to Anna (Ableton/Max) and Jeff (TouchDesigner/Resolume). Off by default.
OSC_ENABLED=false
OSC_HOST=127.0.0.1
OSC_PORT=57121

PORT=8787
HOST=127.0.0.1
