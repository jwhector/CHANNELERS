# Copy to .env and fill in. The brain runs fine without any of these
# (it falls back to deterministic stub seeds), so you can develop with no key.

OPENAI_API_KEY=
TRANSFORM_MODEL=gpt-4o
ORACLE_MODEL=gpt-4o
# OpenAI Whisper STT for the divination mic. Unset → local Xenova whisper-tiny fallback.
STT_MODEL=whisper-1

# ElevenLabs TTS for the oracle voice into the performer's earpiece.
# Unset → falls back to OpenAI TTS (below) if OPENAI_API_KEY is set, else browser
# speechSynthesis. Voices are per-archetype in packages/oracles.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
# Model for the OpenAI TTS fallback (used when ELEVENLABS_API_KEY is unset). Returns
# routable MP3 so the stage's per-device output routing (setSinkId) keeps working;
# only the keyless speechSynthesis path can't be routed.
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# OSC out to Anna (Ableton/Max) and Jeff (TouchDesigner/Resolume). Off by default.
OSC_ENABLED=false
OSC_HOST=127.0.0.1
OSC_PORT=57121

PORT=8787
# Bind address. Dev = loopback; in the cloud container set HOST=0.0.0.0 (else the
# Brain silently refuses external connections).
HOST=127.0.0.1

# ── Single-origin deployment (see DEPLOY.md) ────────────────────────────────
# When true the Brain also serves the stage's Vite build, so one HTTPS origin
# answers the screens (relative /api + /ws). Off in dev (Vite proxies instead);
# the container sets SERVE_STAGE=true.
SERVE_STAGE=false
# Path to the stage build. Defaults to apps/stage/dist; override for other layouts.
# STAGE_DIST=
# WebSocket keepalive ping (ms) so venue/campus proxies don't reap idle sockets. 0 disables.
WS_HEARTBEAT_MS=30000

# Arms the /agent WS endpoint the venue Ableton daemon dials home to (constant-time
# token check). Unset → endpoint off, Brain runs exactly as before. Must match the
# daemon's BRIDGE_TOKEN. See packages/ableton-osc-bridge.
ABLETON_AGENT_TOKEN=
