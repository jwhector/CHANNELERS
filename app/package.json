{
  "name": "channelers",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "seed": "pnpm --filter @channelers/brain seed:visitor",
    "seed:altar": "pnpm --filter @channelers/brain seed:altar",
    "seed:no-intake": "pnpm --filter @channelers/brain seed:no-intake"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
